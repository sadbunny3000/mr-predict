# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://football:football@localhost:5432/football_db
DATABASE_URL_SYNC=postgresql://football:football@localhost:5432/football_db

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Football API (api-football via RapidAPI) ────────────────
API_FOOTBALL_KEY=your_rapidapi_key_here
API_FOOTBALL_HOST=api-football-v1.p.rapidapi.com
API_FOOTBALL_BASE_URL=https://api-football-v1.p.rapidapi.com/v3

# ─── Odds API ────────────────────────────────────────────────
ODDS_API_KEY=your_odds_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4

# ─── Telegram Bot ────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ─── Twilio ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890
TWILIO_TO_NUMBER=+1234567890

# ─── App ─────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change_this_to_a_random_secret_key_in_production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ─── ML ──────────────────────────────────────────────────────
MODEL_DIR=./ml/saved_models
VALUE_BET_EDGE_THRESHOLD=0.10
